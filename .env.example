VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
VITE_SITE_URL=http://localhost:3000
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=

# Convex env vars, set with:
# npx convex env set BETTER_AUTH_SECRET "$(openssl rand -base64 32)"
# npx convex env set SITE_URL http://localhost:3000
# npx convex env set AUTH_EMAIL_FROM "HandleFast <auth@your-domain.com>"
# npx convex env set RESEND_API_KEY re_xxx
# npx convex env set INBOUND_EMAIL_DOMAIN in.handlefast.io
# npx convex env set CLOUDFLARE_EMAIL_WEBHOOK_SECRET "$(openssl rand -base64 32)"
AUTH_EMAIL_FROM=
BETTER_AUTH_SECRET=
CLOUDFLARE_EMAIL_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=in.handlefast.io
RESEND_API_KEY=
SITE_URL=http://localhost:3000

# Cloudflare Worker secret, set with:
# npx wrangler secret put CLOUDFLARE_EMAIL_WEBHOOK_SECRET
# npx wrangler secret put SENTRY_DSN
# Use the same CLOUDFLARE_EMAIL_WEBHOOK_SECRET value for Convex and the Worker.
CONVEX_SITE_URL=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
